	"shadow": {
		"$type": "shadow",
		"sm": {
			"$value": {
				"offsetX": "0px",
				"offsetY": "2px",
				"blur": "4px",
				"spread": "0px",
				"color": "rgba(0, 0, 0, 0.04)"
			}
		},
		"md": {
			"$value": [
				{
					"offsetX": "0px",
