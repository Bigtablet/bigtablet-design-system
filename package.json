{
	"name": "@bigtablet/design-system",
	"version": "3.2.0",
	"description": "Bigtablet Design System UI Components",
	"type": "module",
	"types": "dist/index.d.ts",
	"style": "dist/index.css",
	"repository": {
		"type": "git",
		"url": "https://github.com/Bigtablet/bigtablet-design-system.git"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./style.css": "./dist/index.css",
		"./scss/token": "./dist/styles/token.scss",
		"./vanilla": {
			"style": "./dist/vanilla/bigtablet.min.css",
			"default": "./dist/vanilla/bigtablet.min.js"
		},
		"./vanilla/style.min.css": "./dist/vanilla/bigtablet.min.css",
		"./vanilla/bigtablet.min.js": "./dist/vanilla/bigtablet.min.js"
	},
	"files": [
		"dist",
		"!dist/vanilla/bigtablet.css",
		"!dist/vanilla/bigtablet.js",
		"!dist/vanilla/examples",
		"README.md",
		"LICENSE"
	],
	"sideEffects": [
		"**/*.css",
		"**/*.scss",
		"./dist/next.css"
	],
	"scripts": {
		"build": "tsup && pnpm run copy:scss && pnpm run build:vanilla",
		"build:vanilla": "sh scripts/build-vanilla.sh",
		"copy:scss": "sh scripts/copy-scss.sh",
		"dev": "tsup --watch",
		"storybook": "storybook dev -p 6006",
		"build:sb": "storybook build",
		"protect:sb": "node scripts/protect-storybook.mjs",
		"test": "vitest run --project unit",
		"test:watch": "vitest --project unit",
		"test:coverage": "vitest run --project unit --coverage",
		"test:storybook": "vitest run --project storybook",
		"lint:css": "stylelint 'src/ui/**/*.scss' 'src/styles/**/*.scss'",
		"size": "size-limit",
		"prepare": "husky"
	},
	"keywords": [
		"design-system",
		"react",
		"storybook",
		"ui",
		"vanilla",
		"thymeleaf",
		"html",
		"css"
	],
	"author": "sangmin",
	"license": "MIT",
	"packageManager": "pnpm@10.20.0",
	"peerDependencies": {
		"lucide-react": ">=0.552.0",
		"next": ">=16",
		"react": "^19",
		"react-dom": "^19"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@commitlint/cli": "^21.0.1",
		"@commitlint/core": "^21.0.1",
		"@size-limit/preset-small-lib": "^12.1.0",
		"@storybook/addon-a11y": "^10.4.0",
		"@storybook/addon-docs": "^10.4.0",
		"@storybook/addon-vitest": "^10.4.0",
		"@storybook/react": "^10.4.0",
		"@storybook/react-vite": "^10.4.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser-playwright": "^4.1.6",
		"@vitest/coverage-v8": "^4.1.6",
		"esbuild-sass-plugin": "^3.7.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lucide-react": "^1.16.0",
		"next": "^16.2.6",
		"playwright": "^1.60.0",
		"postcss-scss": "^4.0.9",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"sass-embedded": "^1.99.0",
		"size-limit": "^12.1.0",
		"storybook": "^10.4.0",
		"stylelint": "^17.13.0",
		"tsup": "^8.5.1",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.6"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"size-limit": [
		{
			"path": "dist/index.js",
			"limit": "45 kB"
		},
		{
			"path": "dist/vanilla/bigtablet.min.js",
			"limit": "5 kB"
		}
	],
	"pnpm": {
		"overrides": {
			"rollup": "^4.59.0",
			"lodash": "^4.18.1",
			"lodash-es": "^4.18.1",
			"immutable": "^5.1.5",
			"minimatch": "^10.2.4",
			"handlebars": "^4.7.9",
			"postcss": "^8.5.10",
			"esbuild": "^0.28.1",
			"js-yaml": "^4.2.0",
			"@vitest/browser": "^4.1.8"
		}
	},
	"dependencies": {
		"@react-spring/web": "^10.0.3"
	}
}
