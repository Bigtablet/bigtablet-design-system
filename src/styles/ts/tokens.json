	"motion": {
		"transition": {
			"$type": "duration",
			"fast": {
				"$value": "100ms",
				"$description": "0.1s ease-in-out"
			},
			"base": {
				"$value": "200ms",
				"$description": "0.2s ease-in-out"
			},
			"slow": {
				"$value": "300ms",
				"$description": "0.3s ease-in-out"
			},
			"emphasized": {
				"$value": "250ms",
				"$description": "0.25s cubic-bezier(0.4, 0, 0.2, 1)"
			},
			"bounce": {
				"$value": "300ms",
				"$description": "0.3s cubic-bezier(0.16, 1, 0.3, 1)"
			},
			"fade": {
				"$value": "150ms",
				"$description": "0.15s ease-in-out"
			},
			"slide": {
				"$value": "250ms",
				"$description": "0.25s ease-in-out"
			},
			"scale": {
				"$value": "200ms",
				"$description": "0.2s cubic-bezier(0.2, 0.8, 0.2, 1)"
			},
			"state": {
				"$value": "180ms",
				"$description": "0.18s ease-in-out"
			}
		}
	},
